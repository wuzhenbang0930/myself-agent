{
	"name": "myself-agent",
	"version": "1.0.0",
	"description": "基于 LangChain Deep Agents SDK 的智能助手项目",
	"main": "dist/main.js",
	"scripts": {
		"dev": "nodemon --watch src --ext ts --exec ts-node src/main.ts",
		"dev:simple": "ts-node src/main.ts",
		"start": "node dist/main.js",
		"build": "tsc",
		"build:watch": "tsc --watch",
		"test": "ts-node src/test.ts"
	},
	"keywords": [
		"langchain",
		"deep-agents",
		"ai-agent",
		"openai",
		"dashscope",
		"llm",
		"typescript",
		"chatbot",
		"autonomous-agent",
		"artificial-intelligence",
		"nodejs"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@langchain/core": "^1.1.35",
		"@langchain/openai": "^1.3.0",
		"@types/node": "^25.5.0",
		"chalk": "^5.6.2",
		"deepagents": "^1.8.5",
		"dotenv": "^17.3.1",
		"langchain": "^1.2.36",
		"listr2": "^10.2.1",
		"ora": "^9.3.0",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"nodemon": "^3.1.14"
	}
}
